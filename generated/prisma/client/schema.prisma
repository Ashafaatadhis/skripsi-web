generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Owner {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  kosan        Kosan[]

  @@map("owners")
}

model Kosan {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @map("owner_id") @db.Uuid
  name        String   @db.VarChar(100)
  address     String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  humanId     String   @unique @map("human_id")
  owner       Owner    @relation(fields: [ownerId], references: [id])
  rooms       Room[]
  images      Image[]

  @@map("kosan")
}

model Room {
  id           String   @id @default(uuid()) @db.Uuid
  kosanId      String   @map("kosan_id") @db.Uuid
  name         String   @db.VarChar(50)
  monthlyPrice Int      @map("monthly_price")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  humanId      String   @unique @map("human_id")
  quantity     Int      @default(1)
  facilities   String[] @default([]) @map("facilities")
  rentals      Rental[]
  kosan        Kosan    @relation(fields: [kosanId], references: [id])
  images       Image[]

  @@map("rooms")
}

model Tenant {
  id         String   @id @default(uuid()) @db.Uuid
  telegramId String?  @unique @map("telegram_id")
  name       String   @db.VarChar(100)
  phone      String?  @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  rentals    Rental[]

  @@map("tenants")
}

model Rental {
  id                   String       @id @default(uuid()) @db.Uuid
  humanId              String       @unique @map("human_id")
  roomId               String       @map("room_id") @db.Uuid
  tenantId             String       @map("tenant_id") @db.Uuid
  startDate            DateTime     @map("start_date") @db.Date
  monthlyPriceSnapshot Int          @map("monthly_price_snapshot")
  paidUntil            DateTime?    @map("paid_until") @db.Date
  checkoutDate         DateTime?    @map("checkout_date") @db.Date
  status               RentalStatus @default(active)
  note                 String?
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  room                 Room         @relation(fields: [roomId], references: [id])
  tenant               Tenant       @relation(fields: [tenantId], references: [id])
  payments             Payment[]

  @@map("rentals")
}

model Payment {
  id          String        @id @default(uuid()) @db.Uuid
  humanId     String        @unique @map("human_id")
  rentalId    String        @map("rental_id") @db.Uuid
  monthsPaid  Int           @map("months_paid")
  periodStart DateTime      @map("period_start") @db.Date
  periodEnd   DateTime      @map("period_end") @db.Date
  amount      Int
  paidAt      DateTime?     @map("paid_at") @db.Timestamptz(3)
  status      PaymentStatus @default(pending)
  note        String?
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  rental      Rental        @relation(fields: [rentalId], references: [id])
  images      Image[]

  @@map("payments")
}

model Image {
  id        String   @id @default(uuid()) @db.Uuid
  url       String
  kosanId   String?  @map("kosan_id") @db.Uuid
  roomId    String?  @map("room_id") @db.Uuid
  paymentId String?  @map("payment_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  kosan   Kosan?   @relation(fields: [kosanId], references: [id], onDelete: Cascade)
  room    Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("images")
}

enum RentalStatus {
  active
  cancelled
  checked_out
}

enum PaymentStatus {
  pending
  paid
  overdue
  cancelled
}
